{
  "name": "olos",
  "version": "0.0.0",
  "description": "Open Live Object Streaming protocol primitives.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arsenstorm/olos.git",
    "directory": "olos"
  },
  "bugs": {
    "url": "https://github.com/arsenstorm/olos/issues"
  },
  "homepage": "https://github.com/arsenstorm/olos#readme",
  "main": "./dist/protocol.js",
  "types": "./dist/protocol.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js",
      "default": "./dist/protocol.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./hls": {
      "types": "./dist/hls.d.ts",
      "import": "./dist/hls.js",
      "default": "./dist/hls.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js",
      "default": "./dist/protocol.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js",
      "default": "./dist/state.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "default": "./dist/validation.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "check-types": "tsc --project tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests",
    "prepublishOnly": "bun run build && bun test"
  }
}
